# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres — Settings → Database → Connection string → Transaction pooler (port 6543)
# Format: postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Cron auth — generate with `openssl rand -base64 32`. Same value in Vercel env.
CRON_SECRET=
